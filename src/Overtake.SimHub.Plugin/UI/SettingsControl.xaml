<UserControl x:Class="Overtake.SimHub.Plugin.UI.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <SolidColorBrush x:Key="OvertakeTeal" Color="#2EC4B6" />
        <SolidColorBrush x:Key="OvertakeTealDark" Color="#1FA89C" />
        <SolidColorBrush x:Key="OvertakeBg" Color="#1A1A2E" />
        <SolidColorBrush x:Key="OvertakeCardBg" Color="#16213E" />
        <SolidColorBrush x:Key="OvertakeDim" Color="#7B8CA3" />
        <SolidColorBrush x:Key="OvertakeLight" Color="#E0E0E0" />

        <!-- Botao de aba -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#7B8CA3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1F2A44" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header / Branding -->
            <Border Background="#16213E" CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Overtake Telemetry" FontSize="20" FontWeight="Bold"
                                   Foreground="#2EC4B6" />
                        <TextBlock Text="Captura dados de corrida do F1 25 / F1 26 e envia para o Overtake Race Hub."
                                   Foreground="#7B8CA3" FontSize="12" Margin="0,4,0,6" />
                        <TextBlock Foreground="#7B8CA3" FontSize="11">
                            <Hyperlink x:Name="LnkWebsite" Foreground="#2EC4B6"
                                       NavigateUri="https://racehub.overtakef1.com/"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                racehub.overtakef1.com
                            </Hyperlink>
                            <Run Text="  |  Envie seu JSON e receba resultados, classificacao e estatisticas na hora." />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock x:Name="LblVersion" Text="v1.0.0"
                                   Foreground="#3D4F6B" FontSize="11"
                                   HorizontalAlignment="Right" />
                        <Border x:Name="UpdateBanner" Visibility="Collapsed"
                                Background="#2D2A10" CornerRadius="6" Padding="10,8"
                                Margin="0,6,0,0" MaxWidth="280"
                                BorderBrush="#FFD54F" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="LblUpdateTitle"
                                           Foreground="#FFD54F" FontSize="12" FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Text="Nova versao disponivel" />
                                <TextBlock x:Name="LblUpdateVersion"
                                           Foreground="#FFD54F" FontSize="11" FontWeight="SemiBold"
                                           Margin="0,2,0,0" />
                                <TextBlock x:Name="LblUpdateWarning"
                                           Foreground="#FF8A80" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="LblReleaseNotes"
                                           Foreground="#B0A870" FontSize="10"
                                           TextWrapping="Wrap" Margin="0,4,0,6"
                                           Visibility="Collapsed" />
                                <Button x:Name="BtnUpdateNow"
                                        Content="Baixar e atualizar"
                                        Margin="0,6,0,0" Padding="10,5"
                                        HorizontalAlignment="Left"
                                        Background="#FFD54F" Foreground="#1A1A2E"
                                        FontWeight="SemiBold" BorderThickness="0"
                                        Cursor="Hand"
                                        Click="BtnUpdateNow_Click" />
                                <TextBlock FontSize="10" Margin="0,5,0,0">
                                    <Hyperlink x:Name="LnkUpdate" Foreground="#FFD54F"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        Abrir pagina de download
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Barra de status (sempre visivel) -->
            <Border x:Name="StatusBanner" Background="#16213E" CornerRadius="8"
                    Padding="15,11" Margin="0,0,0,12" BorderBrush="#243049" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="13" Height="13"
                             Fill="#F44336" Margin="0,0,11,0"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="LblStatusMain"
                               Text="Aguardando dados..."
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Abas -->
            <Border Background="#16213E" CornerRadius="8" Padding="4" Margin="0,0,0,14">
                <UniformGrid Rows="1" Columns="4">
                    <Button x:Name="BtnTabStatus" Content="Status" Style="{StaticResource TabButton}" Margin="2" Tag="status" Click="BtnTab_Click" />
                    <Button x:Name="BtnTabLive" Content="Transmitir" Style="{StaticResource TabButton}" Margin="2" Tag="live" Click="BtnTab_Click" />
                    <Button x:Name="BtnTabConfig" Content="Configuracao" Style="{StaticResource TabButton}" Margin="2" Tag="config" Click="BtnTab_Click" />
                    <Button x:Name="BtnTabHelp" Content="Ajuda" Style="{StaticResource TabButton}" Margin="2" Tag="help" Click="BtnTab_Click" />
                </UniformGrid>
            </Border>

            <!-- ================= ABA: STATUS ================= -->
            <StackPanel x:Name="PanelTabStatus">

                <styles:SHSection Title="Status da captura">
                    <StackPanel Margin="10">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,5">
                                <TextBlock Text="PISTA" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblTrack" Text="&#x2014;" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,5">
                                <TextBlock Text="SESSAO" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblSession" Text="&#x2014;" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,5">
                                <TextBlock Text="PILOTOS" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblDrivers" Text="0" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,5">
                                <TextBlock Text="PACOTES" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblPackets" Text="0" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,5">
                                <TextBlock Text="SESSOES" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblSessions" Text="0" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,5">
                                <TextBlock Text="LISTENER" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblStatus" Text="&#x2014;" FontSize="14" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="LblHelpText"
                                   Text="O plugin captura os dados automaticamente quando o F1 25 ou F1 26 esta rodando."
                                   Foreground="#7B8CA3" FontSize="11" Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </styles:SHSection>

                <styles:SHSection Title="Exportar">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="BtnExport"
                                    Content="&#xE896;  EXPORTAR JSON DA LIGA"
                                    Padding="20,10"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Click="BtnExport_Click" />
                            <Button x:Name="BtnOpenFolder"
                                    Content="ABRIR PASTA"
                                    Padding="15,10"
                                    Margin="10,0,0,0"
                                    Click="BtnOpenFolder_Click" />
                        </StackPanel>

                        <TextBlock x:Name="LblExportResult" Text=""
                                   Margin="0,0,0,5" TextWrapping="Wrap" FontStyle="Italic" />

                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="Ultimo export: " Foreground="#7B8CA3" />
                            <TextBlock x:Name="LblLastExport" Text="nenhum ainda" Foreground="#7B8CA3" />
                        </StackPanel>

                        <CheckBox x:Name="ChkAutoExport"
                                  Content="Exportar JSON automaticamente ao terminar a sessao"
                                  Margin="0,8,0,0"
                                  Checked="ChkAutoExport_Changed"
                                  Unchecked="ChkAutoExport_Changed" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="BtnNewSession"
                                    Content="NOVA SESSAO (limpar captura)"
                                    Padding="16,8"
                                    FontSize="12"
                                    Click="BtnNewSession_Click" />
                        </StackPanel>
                        <TextBlock Foreground="#7B8CA3" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Foreground="#FFD54F">Apos exportar</Run>
                            <Run>e antes da proxima corrida ou lobby, clique em Nova Sessao para apagar telemetria em memoria. O UDP continua ativo; evita misturar duas corridas no mesmo ficheiro.</Run>
                        </TextBlock>

                        <TextBlock Foreground="#7B8CA3" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                            <Run>Envie seu JSON exportado em</Run>
                            <Hyperlink Foreground="#2EC4B6"
                                       NavigateUri="https://racehub.overtakef1.com/"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                racehub.overtakef1.com
                            </Hyperlink>
                            <Run>para receber resultados, classificacao e estatisticas na hora.</Run>
                        </TextBlock>
                    </StackPanel>
                </styles:SHSection>

            </StackPanel>

            <!-- ================= ABA: TRANSMITIR ================= -->
            <StackPanel x:Name="PanelTabLive" Visibility="Collapsed">
                <styles:SHSection Title="Transmissao ao vivo (overtakef1)">
                    <StackPanel Margin="10">
                        <Border Background="#2A2210" CornerRadius="6" Padding="12,10" Margin="0,0,0,12" BorderBrush="#5C4A10" BorderThickness="1">
                            <TextBlock TextWrapping="Wrap" FontSize="11">
                                <Run FontWeight="Bold" Foreground="#FFD54F">&#x2605;  Exclusivo de ligas Elite ou Founder.</Run>
                                <LineBreak />
                                <Run Foreground="#B9A66A">A geracao do token e a transmissao ao vivo estao disponiveis apenas para admins de ligas Elite/Founder.</Run>
                            </TextBlock>
                        </Border>

                        <TextBlock TextWrapping="Wrap" Foreground="#7B8CA3" FontSize="12" Margin="0,0,0,10">
                            <Run FontWeight="Bold" Foreground="#2EC4B6">Leve a corrida ao vivo para o portal overtakef1.</Run>
                            <Run>Gere o token em Perfil &gt; Transmissao / SimHub no site, cole abaixo, conecte, escolha a liga/grid/corrida e clique IR AO AR. Nao afeta o arquivo .otk.</Run>
                        </TextBlock>

                        <TextBlock Text="1 &#xB7; Token de transmissao" FontWeight="Bold" Foreground="#2EC4B6" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBox x:Name="TxtLiveToken"
                                     Width="320"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BtnSaveLiveToken"
                                    Content="SALVAR"
                                    Padding="15,5"
                                    Click="BtnSaveLiveToken_Click" />
                            <Button x:Name="BtnLiveConnect"
                                    Content="CONECTAR"
                                    Padding="15,5"
                                    Margin="10,0,0,0"
                                    Click="BtnLiveConnect_Click" />
                        </StackPanel>

                        <TextBlock Text="2 &#xB7; Onde transmitir" FontWeight="Bold" Foreground="#2EC4B6" Margin="0,12,0,4" />
                        <TextBlock Text="Liga" FontWeight="Bold" Margin="0,0,0,3" />
                        <ComboBox x:Name="CmbLeague" Margin="0,0,0,8"
                                  SelectionChanged="CmbLeague_SelectionChanged" />

                        <TextBlock Text="Grid / temporada" FontWeight="Bold" Margin="0,0,0,3" />
                        <ComboBox x:Name="CmbGrid" Margin="0,0,0,8"
                                  SelectionChanged="CmbGrid_SelectionChanged" />

                        <StackPanel x:Name="PanelExistingRace">
                            <TextBlock Text="Corrida agendada" FontWeight="Bold" Margin="0,0,0,3" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="CmbRace" Width="320" Margin="0,0,10,0" />
                                <Button x:Name="BtnRefreshRaces" Content="ATUALIZAR" Padding="12,5"
                                        Click="BtnRefreshRaces_Click" />
                            </StackPanel>
                            <Button x:Name="BtnToggleNewRace" Content="Criar nova corrida..."
                                    Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,8"
                                    Click="BtnToggleNewRace_Click" />
                        </StackPanel>

                        <StackPanel x:Name="PanelNewRace" Visibility="Collapsed" Margin="0,0,0,8">
                            <TextBlock Text="Pista (lista oficial)" FontWeight="Bold" Margin="0,0,0,3" />
                            <ComboBox x:Name="CmbNewTrack" Margin="0,0,0,8" />
                            <TextBlock Text="Data" FontWeight="Bold" Margin="0,0,0,3" />
                            <DatePicker x:Name="DpNewRaceDate" Margin="0,0,0,8" HorizontalAlignment="Left" />
                            <TextBlock Text="Hora (HH:MM)" FontWeight="Bold" Margin="0,0,0,3" />
                            <TextBox x:Name="TxtNewRaceTime" Width="80" Text="20:00"
                                     VerticalContentAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnCreateRace" Content="CRIAR CORRIDA" Padding="14,5"
                                        Click="BtnCreateRace_Click" />
                                <Button x:Name="BtnCancelNewRace" Content="Cancelar" Padding="12,5"
                                        Margin="10,0,0,0" Click="BtnToggleNewRace_Click" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Tipo de sessao" FontWeight="Bold" Margin="0,0,0,3" />
                        <ComboBox x:Name="CmbSessionType" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="BtnGoLive"
                                    Content="&#x1F4E1;  IR AO AR"
                                    Padding="22,9"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Click="BtnGoLive_Click" />
                            <Button x:Name="BtnEndLive"
                                    Content="ENCERRAR"
                                    Padding="18,9"
                                    Margin="10,0,0,0"
                                    IsEnabled="False"
                                    Click="BtnEndLive_Click" />
                        </StackPanel>

                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="STATUS" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblLiveStatus" Text="ocioso"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </styles:SHSection>
            </StackPanel>

            <!-- ================= ABA: CONFIGURACAO ================= -->
            <StackPanel x:Name="PanelTabConfig" Visibility="Collapsed">

                <styles:SHSection Title="Conexao do jogo">
                    <StackPanel Margin="10">
                        <TextBlock Text="Porta UDP" FontWeight="Bold" Margin="0,0,0,3" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="TxtPort"
                                     Width="80"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BtnApplyPort"
                                    Content="APLICAR"
                                    Padding="15,5"
                                    Click="BtnApplyPort_Click" />
                            <TextBlock Text="Deve bater com a porta de telemetria do jogo (padrao: 20778)"
                                       Foreground="#7B8CA3" FontSize="11"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="Pasta de saida" FontWeight="Bold" Margin="0,5,0,3" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBox x:Name="TxtOutputFolder"
                                     Width="350"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="True"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BtnBrowse"
                                    Content="PROCURAR..."
                                    Padding="15,5"
                                    Click="BtnBrowse_Click" />
                        </StackPanel>
                    </StackPanel>
                </styles:SHSection>

                <styles:SHSection Title="Race UI (web) &#x2014; opcional">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Foreground="#7B8CA3" FontSize="12" Margin="0,0,0,8">
                            <Run FontWeight="Bold" Foreground="#2EC4B6">Overlay da corrida em tempo real (OBS).</Run>
                            <Run>Pagina local que mostra a corrida ao vivo (classificacao, pneus, ERS, combustivel, danos, punicoes). Independente da transmissao para o portal.</Run>
                        </TextBlock>

                        <CheckBox x:Name="ChkRaceUi"
                                  Content="Ativar Race UI (servidor web local)"
                                  Margin="0,0,0,8"
                                  Checked="ChkRaceUi_Changed"
                                  Unchecked="ChkRaceUi_Changed" />

                        <TextBlock Text="Porta" FontWeight="Bold" Margin="0,0,0,3" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="TxtRaceUiPort"
                                     Width="80"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BtnApplyRaceUi"
                                    Content="APLICAR"
                                    Padding="15,5"
                                    Click="BtnApplyRaceUi_Click" />
                            <TextBlock Text="Padrao: 8088"
                                       Foreground="#7B8CA3" FontSize="11"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>

                        <CheckBox x:Name="ChkRaceUiLan"
                                  Content="Permitir acesso na rede local (LAN / segundo PC / celular)"
                                  Margin="0,0,0,10"
                                  Checked="ChkRaceUi_Changed"
                                  Unchecked="ChkRaceUi_Changed" />

                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="ENDERECO" FontSize="10" Foreground="#2EC4B6" FontWeight="Bold" />
                                <TextBlock x:Name="LblRaceUiUrl" Text="desativado"
                                           FontSize="15" FontWeight="SemiBold" Margin="0,2,0,8" />
                                <Button x:Name="BtnOpenRaceUi"
                                        Content="ABRIR NO NAVEGADOR"
                                        Padding="15,6"
                                        HorizontalAlignment="Left"
                                        Click="BtnOpenRaceUi_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </styles:SHSection>

            </StackPanel>

            <!-- ================= ABA: AJUDA ================= -->
            <StackPanel x:Name="PanelTabHelp" Visibility="Collapsed">

                <styles:SHSection Title="Guia de configuracao (PC)">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Foreground="#CCC" FontSize="12">
                            <Run FontWeight="Bold" Foreground="#2EC4B6">PASSO 1 - Configuracao no jogo (F1 25/26):</Run>
                            <LineBreak />
                            <Run>Ajustes > Telemetria > Telemetria UDP = Ligado</Run>
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="#FFD54F">UDP IP = 127.0.0.1  |  Porta UDP = 20778  |  Formato = 2025 (F1 25) / 2026 (F1 26)</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">PASSO 2 - Config do jogo no SimHub (IMPORTANTE):</Run>
                            <LineBreak />
                            <Run>SimHub Home > Codemasters F1 25 > "Game config..."</Run>
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="#FFD54F">Defina a Porta UDP = 20777</Run>
                            <LineBreak />
                            <Run Foreground="#7B8CA3">(O SimHub detecta 20778 do jogo. Voce PRECISA mudar de volta para 20777.)</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">Como funciona:</Run>
                            <LineBreak />
                            <Run>Jogo (20778)  &#x2192;  Plugin Overtake  &#x2192;  repasse  &#x2192;  SimHub (20777)</Run>
                            <LineBreak />
                            <Run Foreground="#7B8CA3">O plugin recebe a telemetria, processa e repassa cada pacote ao SimHub, para seus dashboards continuarem funcionando.</Run>
                        </TextBlock>
                    </StackPanel>
                </styles:SHSection>

                <styles:SHSection Title="Guia (Console - PS5 / Xbox)">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Foreground="#CCC" FontSize="12">
                            <Run Foreground="#7B8CA3">F1 25 / F1 26 no PlayStation e Xbox podem enviar telemetria para um PC na mesma rede.</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">PASSO 1 - Descubra o IP do seu PC:</Run>
                            <LineBreak />
                            <Run>No PC, abra o CMD e digite:  </Run>
                            <Run FontWeight="Bold" Foreground="#FFD54F">ipconfig</Run>
                            <LineBreak />
                            <Run>Procure por "Endereco IPv4" (ex.: 192.168.1.100)</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">PASSO 2 - Config no console:</Run>
                            <LineBreak />
                            <Run>Ajustes > Telemetria > Telemetria UDP = Ligado</Run>
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="#FFD54F">UDP IP = o IP do seu PC (ex.: 192.168.1.100)</Run>
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="#FFD54F">Porta UDP = 20778  |  Formato = 2025 (F1 25) / 2026 (F1 26)</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">PASSO 3 - SimHub (igual ao Passo 2 do PC):</Run>
                            <LineBreak />
                            <Run>Home > Codemasters F1 25 > Game config > </Run>
                            <Run FontWeight="Bold" Foreground="#FFD54F">Porta UDP = 20777</Run>
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="#2EC4B6">Requisitos:</Run>
                            <LineBreak />
                            <Run Foreground="#7B8CA3">- Console e PC na mesma rede local (Wi-Fi ou cabo)</Run>
                            <LineBreak />
                            <Run Foreground="#7B8CA3">- Firewall do Windows deve permitir UDP na porta 20778</Run>
                            <LineBreak />
                            <Run Foreground="#7B8CA3">- SimHub rodando no PC durante a sessao</Run>
                        </TextBlock>
                    </StackPanel>
                </styles:SHSection>

                <styles:SHSection Title="Sobre">
                    <StackPanel Margin="10">
